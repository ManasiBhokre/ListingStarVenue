<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/cardBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Left content block -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Venue Name -->
            <TextView
                android:id="@+id/tv_venue_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Venue Name"
                android:textColor="@color/textPrimary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end" />

            <!-- Category badge -->
            <TextView
                android:id="@+id/tv_venue_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Category"
                android:textColor="@color/colorAccent"
                android:textSize="12sp"
                android:textStyle="italic" />

            <!-- Address -->
            <TextView
                android:id="@+id/tv_venue_address"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:drawablePadding="4dp"
                android:text="Address"
                android:textColor="@color/textSecondary"
                android:textSize="13sp"
                android:maxLines="2"
                android:ellipsize="end" />

            <!-- Bottom row: distance + checkins -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_venue_distance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Distance"
                    android:textColor="@color/colorPrimary"
                    android:textSize="12sp"
                    android:background="@drawable/bg_badge"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:visibility="gone"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp" />

                <TextView
                    android:id="@+id/tv_checkins"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Checkins: 0"
                    android:textColor="@color/textSecondary"
                    android:textSize="12sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Star button -->
        <ImageButton
            android:id="@+id/ib_star"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Save venue"
            android:padding="4dp"
            android:src="@drawable/ic_star_outlined" />

    </LinearLayout>

</androidx.cardview.widget.CardView>